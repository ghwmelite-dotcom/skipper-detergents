# Normalize line endings across platforms — LF in the repo AND in working trees.
# Overrides per-user core.autocrlf so Windows contributors don't fight prettier/CI.

* text=auto eol=lf

# Binary files — never text-normalize these
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.pdf binary
*.zip binary
*.gz binary
*.woff binary
*.woff2 binary

# Lockfiles — generated, leave alone
pnpm-lock.yaml -diff
